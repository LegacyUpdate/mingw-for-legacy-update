diff --git a/gcc/testsuite/g++.dg/modules/part-11_c.C b/gcc/testsuite/g++.dg/modules/part-11_c.C
new file mode 100644
index 000000000000..2fb4aad0b120
--- /dev/null
+++ b/gcc/testsuite/g++.dg/modules/part-11_c.C
@@ -0,0 +1,6 @@
+// PR c++/124309
+// { dg-additional-options "-fmodules" }
+// { dg-module-cmi Z:part }
+
+export module Z:part;
+export import X;
diff --git a/gcc/testsuite/g++.dg/modules/part-11_d.C b/gcc/testsuite/g++.dg/modules/part-11_d.C
new file mode 100644
index 000000000000..a21b9546a9a7
--- /dev/null
+++ b/gcc/testsuite/g++.dg/modules/part-11_d.C
@@ -0,0 +1,7 @@
+// PR c++/124309
+// { dg-additional-options "-fmodules" }
+// { dg-module-cmi Z }
+
+export module Z;
+export import Y;
+export import :part;
diff --git a/gcc/testsuite/g++.dg/modules/part-11_e.C b/gcc/testsuite/g++.dg/modules/part-11_e.C
new file mode 100644
index 000000000000..9a41ae2cb707
--- /dev/null
+++ b/gcc/testsuite/g++.dg/modules/part-11_e.C
@@ -0,0 +1,10 @@
+// PR c++/124309
+// { dg-additional-options "-fmodules" }
+
+import Z;
+
+int main() {
+  frob(2);  // { dg-error "invalid conversion" }
+}
