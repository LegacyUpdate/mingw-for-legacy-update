@@ -30,7 +30,7 @@ func_add_eor (uint64x2_t a, uint64x2_t b) {
 
 /*
 ** func_shl_orr:
-**	xar	v0\.2d, v([0-9]+)\.2d, v([0-9]+)\.2d, 63
+**	xar	v0\.2d, v([0-9]+)\.2d, v([0-9]+)\.2d, #63
 **	ret 
 */
 uint64x2_t
@@ -41,7 +41,7 @@ func_shl_orr (uint64x2_t a, uint64x2_t b) {
 
 /*
 ** func_add_orr:
-**	xar	v0\.2d, v([0-9]+)\.2d, v([0-9]+)\.2d, 63
+**	xar	v0\.2d, v([0-9]+)\.2d, v([0-9]+)\.2d, #63
 **	ret 
 */
