+
+uint8_t e[a], x[a];
+int64_t f[a], g[a], l[a];
+float j[a], k[a], m[a];
+
+int main() {
+  for (int i = 0; i < a; ++i) { e[i]=1; g[i] = 86; x[i] = 86; }
+  for (size_t n = 0, avl = a; avl;) {
+    size_t o = __riscv_vsetvl_e64m8(avl);
