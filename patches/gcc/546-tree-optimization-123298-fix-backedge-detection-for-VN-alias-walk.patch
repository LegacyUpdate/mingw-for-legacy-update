 gcc/tree-ssa-alias.h                    |  7 +++--
 gcc/tree-ssa-pre.cc                     | 10 +++----
 gcc/tree-ssa-sccvn.cc                   | 21 ++++++++++++---
 gcc/tree-ssa-scopedtables.cc            |  2 +-
